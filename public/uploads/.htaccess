# Dossier d'uploads — images servies aux visiteurs, mais AUCUNE exécution de
# code (défense contre un upload malveillant qui passerait les filtres).
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
<IfModule mod_php7.c>
  php_flag engine off
</IfModule>
<IfModule mod_php8.c>
  php_flag engine off
</IfModule>

# Neutralise tout handler dynamique + interdit l'appel direct de scripts.
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phar .cgi .pl .py
RemoveType .php .phtml .phar
AddType text/plain .php .phtml .phar .cgi .pl .py
<FilesMatch "(?i)\.(php\d?|phtml|phar|cgi|pl|py|asp|aspx|sh|exe)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

Options -ExecCGI -Indexes
