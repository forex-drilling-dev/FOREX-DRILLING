# ==========================================================================
# Panneau d'admin du CMS — durcissement Apache.
# ==========================================================================

# --- En-têtes de sécurité (toujours actifs) ---
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
</IfModule>
Options -Indexes

# --- BARRIÈRE 1 : Apache Basic Auth (défense en profondeur, devant le login PHP) ---
# À ACTIVER au déploiement. Deux options (voir docs/cms.md) :
#
#   A) cPanel → « Confidentialité du répertoire » (Directory Privacy) sur /admin :
#      cPanel écrit lui-même le bloc Auth + le bon AuthUserFile. Rien à décommenter.
#
#   B) Manuel : créer un .htpasspwd HORS racine web puis décommenter, en mettant
#      le chemin ABSOLU réel (un mauvais chemin renvoie une erreur 500) :
#
# AuthType Basic
# AuthName "Forex Drilling CMS"
# AuthUserFile "/home/UTILISATEUR/.htpasswd"
# Require valid-user
#
# (La BARRIÈRE 2 — login session PHP + CSRF + rate-limit — est TOUJOURS active,
#  quel que soit l'état de la barrière 1.)
