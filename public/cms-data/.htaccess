# Données du CMS — JAMAIS accessibles en HTTP (articles, hash, audit, secrets).
# Le code PHP les lit par le système de fichiers, pas par le web.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order allow,deny
  Deny from all
</IfModule>
Options -Indexes
