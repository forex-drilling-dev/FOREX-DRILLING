RESEND_API_KEY=
CONTACT_TO_EMAIL=admin@forexdrilling.com
CONTACT_FROM_EMAIL=website@forexdrilling.com

# Optional — override the contact form endpoint. Defaults to /contact.php
# (the PHP relay shipped to the site root). Only set this to point the form
# at a different URL.
NEXT_PUBLIC_CONTACT_ENDPOINT=/contact.php

# News CMS read API. In production this is same-origin (/api/news.php, the PHP
# read endpoint shipped to the site root). For local `next dev`, point it at a
# running PHP server or the live host so the news section populates.
NEXT_PUBLIC_NEWS_ENDPOINT=/api/news.php
